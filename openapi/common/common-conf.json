{
  "$schema": "https://raw.githubusercontent.com/cyclosproject/ng-openapi-gen/master/ng-openapi-gen-schema.json",
  "input": "./openapi/common/common.json",
  "output": "./src/app/core/backend/common",
  "ignoreUnusedModels": false,
  "module": "CommonApiModule",
  "skipJsonSuffix": true,
  "removeStaleFiles": true,
  "templates": "./openapi/templates"
}