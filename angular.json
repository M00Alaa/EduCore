{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "vult-system": {
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss",
                    "skipTests": true,
                    "standalone": false
                },
                "@schematics/angular:pipe": {
                    "skipTests": true,
                    "standalone": true
                }
            },
            "projectType": "application",
            "root": "",
            "sourceRoot": "src",
            "prefix": "mo",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                        "stylePreprocessorOptions": {
                            "includePaths": [
                                "src/assets/scss",
                                "src/assets/less",
                                "."
                            ]
                        },
                        "outputPath": {
                            "base": "dist"
                        },
                        "index": "src/index.html",
                        "polyfills": [
                            "zone.js",
                            "@angular/localize/init"
                        ],
                        "tsConfig": "tsconfig.app.json",
                        "assets": [
                            "src/favicon.ico",
                            "src/assets",
                            "src/.htaccess"
                        ],
                        "styles": [
                            "src/assets/less/ngZorro.less",
                            "src/assets/scss/icons.scss",
                            "./node_modules/leaflet/dist/leaflet.css",
                            {
                                "input": "src/assets/scss/app.scss",
                                "bundleName": "app-ltr",
                                "inject": false
                            },
                            {
                                "input": "src/assets/scss/app-rtl.scss",
                                "bundleName": "app-rtl",
                                "inject": false
                            },
                            {
                                "input": "src/assets/scss/bootstrap.scss",
                                "bundleName": "bootstrap",
                                "inject": false
                            },
                            {
                                "input": "src/assets/scss/bootstrap-dark.scss",
                                "bundleName": "bootstrap-dark",
                                "inject": false
                            }
                        ],
                        "scripts": [],
                        "browser": "src/main.ts"
                    },
                    "configurations": {
                        "stage": {
                            "outputPath": {
                                "base": "dist"
                            },
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.stage.ts"
                                }
                            ],
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "1kb",
                                    "maximumError": "10mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "5kb",
                                    "maximumError": "20kb"
                                }
                            ],
                            "outputHashing": "all",
                            "optimization": true,
                            "extractLicenses": true,
                            "sourceMap": true,
                            "subresourceIntegrity": true
                        },
                        "production": {
                            "outputPath": {
                                "base": "dist"
                            },
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.prod.ts"
                                }
                            ],
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "1kb",
                                    "maximumError": "5mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "5kb",
                                    "maximumError": "20kb"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "outputPath": {
                                "base": "dist"
                            },
                            "fileReplacements": [
                                {
                                    "replace": "src/environments/environment.ts",
                                    "with": "src/environments/environment.ts"
                                }
                            ],
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "stage"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "stage": {
                            "buildTarget": "vult-system:build:stage"
                        },
                        "production": {
                            "buildTarget": "vult-system:build:production"
                        },
                        "development": {
                            "buildTarget": "vult-system:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "polyfills": [
                            "zone.js",
                            "zone.js/testing"
                        ],
                        "tsConfig": "tsconfig.spec.json",
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ],
                        "styles": [
                            "src/styles.css"
                        ],
                        "scripts": []
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "lintFilePatterns": [
                            "src/**/*.ts",
                            "src/**/*.html"
                        ]
                    }
                }
            }
        }
    },
    "cli": {
        "schematicCollections": [
            "@angular-eslint/schematics"
        ],
        "cache": {
            "enabled": true
        },
        "packageManager": "npm",
        "warnings": {
            "versionMismatch": false
        },
        "analytics": false
    }
}