{
  "name": "edu-core",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "run": "npm run api && ng s --o",
    "serve": "ng serve --o",
    "build": "node --max_old_space_size=4098 node_modules/@angular/cli/bin/ng build --configuration stage",
    "build-prod": "node --max_old_space_size=4098 node_modules/@angular/cli/bin/ng build --configuration production",
    "start": "node --max_old_space_size=4098 node_modules/@angular/cli/bin/ng serve --o",
    "dev": "npm run start",
    "test": "ng test",
    "lint": "ng lint",
    "api-common": "node ./openapi/mg-p2o.js ./openapi/common/postman-collection.json  ./openapi/common/common.json  && ng-openapi-gen -c openapi/common/common-conf.json",
    "api-academy": "node ./openapi/mg-p2o.js ./openapi/academy/postman-collection.json  ./openapi/academy/academy.json  && ng-openapi-gen -c openapi/academy/academy-conf.json",
    "api": "npm run api-common && npm run api-academy"
  },
  "private": true,
